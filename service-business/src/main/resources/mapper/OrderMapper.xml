<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.business.mapper.OrderMapper">

    <resultMap id="OrderDetailMap" type="com.example.business.dto.OrderDetailDTO">
        <result column="order_id" property="orderId"/>
        <result column="order_no" property="orderNo"/>
        <result column="amount" property="amount"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="user_name" property="userName"/>
        <result column="user_phone" property="userPhone"/>
        <result column="product_name" property="productName"/>
        <result column="product_category" property="productCategory"/>
        <result column="shop_name" property="shopName"/>
    </resultMap>

    <!-- 公共的外层 SELECT + JOIN 片段 -->
    <sql id="orderDetailColumns">
        SELECT
            o.id          AS order_id,
            o.order_no,
            o.amount,
            o.status,
            o.create_time,
            u.user_name,
            u.phone       AS user_phone,
            p.product_name,
            p.category    AS product_category,
            s.shop_name
        FROM orders o
    </sql>

    <sql id="orderDetailJoins">
        LEFT JOIN users u ON o.user_id = u.id
        LEFT JOIN products p ON o.product_id = p.id
        LEFT JOIN shops s ON o.shop_id = s.id
        ORDER BY o.id ASC
    </sql>

    <!-- 游标分页：无条件 -->
    <select id="selectOrderDetailByCursor" resultMap="OrderDetailMap">
        <include refid="orderDetailColumns"/>
        INNER JOIN (
            SELECT id FROM orders
            WHERE id > #{cursor}
            ORDER BY id ASC
            LIMIT #{pageSize}
        ) tmp ON o.id = tmp.id
        <include refid="orderDetailJoins"/>
    </select>

    <!-- 游标分页：带条件 -->
    <select id="selectOrderDetailByCursorWithCondition" resultMap="OrderDetailMap">
        <include refid="orderDetailColumns"/>
        INNER JOIN (
            SELECT id FROM orders
            WHERE id > #{cursor}
            <if test="status != null">
                AND status = #{status}
            </if>
            ORDER BY id ASC
            LIMIT #{pageSize}
        ) tmp ON o.id = tmp.id
        <include refid="orderDetailJoins"/>
    </select>

    <!-- OFFSET 分页（混合分页用） -->
    <select id="selectOrderDetailByOffset" resultMap="OrderDetailMap">
        <include refid="orderDetailColumns"/>
        INNER JOIN (
            SELECT id FROM orders
            WHERE 1=1
            <if test="status != null">
                AND status = #{status}
            </if>
            ORDER BY id ASC
            LIMIT #{offset}, #{pageSize}
        ) tmp ON o.id = tmp.id
        <include refid="orderDetailJoins"/>
    </select>

    <!-- 总记录数 -->
    <select id="countOrders" resultType="long">
        SELECT COUNT(*) FROM orders
        <where>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
    </select>

</mapper>
